# Core
GOOGLE_API_KEY=your_google_api_key_here
ADK_MODEL=gemini-2.5-flash
APP_ENV=development
LOG_LEVEL=INFO

# Voice - Gemini Live API (Primary, later phase)
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_API_ENDPOINT=wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1alpha.GenerativeService.BidiGenerateContent
ENABLE_LIVE_API=false

# Voice - TTS/STT Pipeline (Fallback, later phase)
STT_PROVIDER=deepgram
TTS_PROVIDER=gemini-tts
DEEPGRAM_API_KEY=your_deepgram_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Audio Settings (later phase)
AUDIO_INPUT_SAMPLE_RATE=16000
AUDIO_OUTPUT_SAMPLE_RATE=24000
AUDIO_CHUNK_SIZE_MS=20
VAD_AGGRESSIVENESS=2

